class FactSetClient:
    """Secure FactSet API client with rate limiting and error handling"""
    
    def __init__(self):
        self.session = requests.Session()
        self.session.headers.update({
            'Authorization': f'Bearer {CONFIG["factset"]["api_key"]}',
            'Accept': 'application/json'
        })
        self.last_call = datetime.min
        self.min_interval = timedelta(milliseconds=100)  # 10 requests/sec
        
    def get_historical_news(self, ticker: str, start_date: str, end_date: str) -> pd.DataFrame:
        """Retrieve news for a single ticker with rate limiting"""
        try:
            # Enforce rate limit
            wait_time = (self.min_interval - (datetime.now() - self.last_call)).total_seconds()
            if wait_time > 0:
                time.sleep(wait_time)
                
            params = {
                'symbols': ticker,
                'startDate': start_date,
                'endDate': end_date,
                'fields': 'headline,publicationTime'
            }
            
            response = self.session.get(
                f"{CONFIG['factset']['base_url']}/historical",
                params=params
            )
            response.raise_for_status()
            
            self.last_call = datetime.now()
            
            # Convert to DataFrame with financial data normalization
            data = response.json().get('data', [])
            return pd.DataFrame([{
                'timestamp': pd.to_datetime(item['publicationTime']).tz_convert('America/New_York'),
                'ticker': ticker,
                'headline': item['headline'].strip()
            } for item in data])
            
        except Exception as e:
            logging.error(f"FactSet API error for {ticker}: {str(e)}")
            return pd.DataFrame()

class DeepSeekAnalyzer:
    """LLM Sentiment Analysis with Enterprise-grade Error Handling"""
    
    def __init__(self):
        self.session = requests.Session()
        self.session.headers.update({
            'Authorization': f'Bearer {CONFIG["deepseek"]["api_key"]}',
            'Content-Type': 'application/json'
        })
        self.rate_limit = 500  # Assuming tier 1 rate limit
        self.token_count = 0
        
    def analyze_sentiment(self, headline: str, company: str, term: str = 'short') -> Tuple[str, str]:
        """Get structured sentiment analysis with cost control"""
        try:
            if self.token_count >= self.rate_limit:
                logging.warning("Rate limit reached - cooling down")
                time.sleep(60)
                self.token_count = 0
                
            prompt = f"Answer 'YES' if good news, 'NO' if bad news, or 'UNKNOWN' if uncertain in the first line. Then elaborate with one short sentence. Answer: Is this headline good or bad for the stock price of {company} in the {term} term? Headline: {headline}"
            
            response = self.session.post(
                CONFIG['deepseek']['base_url'],
                json={
                    'model': 'deepseek-llm',
                    'messages': [{'role': 'user', 'content': prompt}],
                    'temperature': 0.1
                }
            )
            response.raise_for_status()
            
            self.token_count += response.json().get('usage', {}).get('total_tokens', 0)
            
            content = response.json()['choices'][0]['message']['content']
            sentiment = content.split('\n')[0].strip().upper()
            explanation = ' '.join(content.split('\n')[1:]).strip()
            
            # Validate LLM output
            if sentiment not in {'YES', 'NO', 'UNKNOWN'}:
                return 'UNKNOWN', 'Invalid sentiment format'
                
            return sentiment, explanation
            
        except Exception as e:
            logging.error(f"DeepSeek API error: {str(e)}")
            return 'UNKNOWN', str(e)

class TradingStrategy:
    """Quantitative Strategy Engine with Risk Management"""
    
    @staticmethod
    def generate_signals(df: pd.DataFrame) -> pd.DataFrame:
        """Convert sentiment to trading signals with financial rigor"""
        df['action'] = np.where(
            df['sentiment'] == 'YES', 'LONG',
            np.where(df['sentiment'] == 'NO', 'SHORT', 'HOLD')
        )
        return df[df['action'] != 'HOLD']

class Backtester:
    """Event-Driven Backtesting Engine with Financial Metrics"""
    
    def __init__(self, price_data: pd.DataFrame):
        self.price_data = price_data.set_index(['date', 'ticker'])
        self.positions = {}
        
    def run_backtest(self, signals: pd.DataFrame) -> pd.DataFrame:
        """Simulate trading based on signals with market realism"""
        results = []
        
        for _, row in signals.sort_values('timestamp').iterrows():
            try:
                # Get next day's return (simplified - real implementation needs execution logic)
                execution_date = row['timestamp'].date() + timedelta(days=1)
                future_data = self.price_data.loc[execution_date].loc[row['ticker']]
                returns = future_data['return']
                
                results.append({
                    'timestamp': row['timestamp'],
                    'ticker': row['ticker'],
                    'headline': row['headline'],
                    'sentiment': row['sentiment'],
                    'action': row['action'],
                    'returns': returns if row['action'] == 'LONG' else -returns
                })
                
            except KeyError:
                logging.warning(f"Missing price data for {row['ticker']} on {execution_date}")
                
        return pd.DataFrame(results).dropna()

    @staticmethod
    def calculate_metrics(results: pd.DataFrame) -> Dict:
        """Compute professional performance metrics"""
        returns = results.set_index('timestamp')['returns']
        
        return {
            'sharpe_ratio': (returns.mean() * 252) / (returns.std() * np.sqrt(252)),
            'max_drawdown': (returns.cumsum().expanding().max() - returns.cumsum()).max(),
            'total_return': returns.sum()
        }

